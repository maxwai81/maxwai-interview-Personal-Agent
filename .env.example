# n8n Self-Hosted Server Configuration
# Copy this file to .env and fill in your actual values

# Your self-hosted n8n server URL (e.g., https://n8n.yourdomain.com or http://localhost:5678)
N8N_API_URL=http://localhost:5678

# Your n8n API key (Settings → API in your n8n instance)
N8N_API_KEY=your-api-key-here
